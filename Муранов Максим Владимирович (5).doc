}\cell\pard\intbl\itap1{\fs50\b \uc0\u1052 \uc0\u1091 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074  \uc0\u1052 \uc0\u1072 \uc0\u1082 \uc0\u1089 \uc0\u1080 \uc0\u1084  \uc0\u1042 \uc0\u1083 \uc0\u1072 \uc0\u1076 \uc0\u1080 \uc0\u1084 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1080 \uc0\u1095 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1052 \uc0\u1091 \uc0\u1078 \uc0\u1095 \uc0\u1080 \uc0\u1085 \uc0\u1072 , 37\uc0\u160 \uc0\u1083 \uc0\u1077 \uc0\u1090 , \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1083 \uc0\u1089 \uc0\u1103  17 \uc0\u1084 \uc0\u1072 \uc0\u1103  1988}\par\pard\intbl\sl260{\fs18 \par +7\uc0\u160 (908)\uc0\u160 0404908 {\cf1\emdash  \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1087 \uc0\u1086 \uc0\u1095 \uc0\u1080 \uc0\u1090 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1099 \uc0\u1081  \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1073  \uc0\u1089 \uc0\u1074 \uc0\u1103 \uc0\u1079 \uc0\u1080 }\par {{\field{\*\fldinst HYPERLINK "mailto:89080404908@mail.ru"}{\fldrslt\ul 89080404908@mail.ru}}}}\par\pard\intbl\sl260{\fs18 \par \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1078 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1077 \uc0\u1090 : \uc0\u1052 \uc0\u1086 \uc0\u1089 \uc0\u1082 \uc0\u1074 \uc0\u1072 , \uc0\u1084 . \uc0\u1052 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1085 \uc0\u1086 \par \uc0\u1043 \uc0\u1088 \uc0\u1072 \uc0\u1078 \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 : \uc0\u1056 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1103 , \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1077 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1085 \uc0\u1072  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1091 : \uc0\u1056 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1103 \par \uc0\u1053 \uc0\u1077  \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1082  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1077 \uc0\u1079 \uc0\u1076 \uc0\u1091 , \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1082  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072 \uc0\u1084 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1046 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1072 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1083 \uc0\u1078 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1088 \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1072 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa100\sl280{\fs24\b \uc0\u1052 \uc0\u1072 \uc0\u1082 \uc0\u1089 \uc0\u1080 \uc0\u1084  \uc0\u1042 \uc0\u1083 \uc0\u1072 \uc0\u1076 \uc0\u1080 \uc0\u1084 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1080 \uc0\u1095  \uc0\u1052 \uc0\u1091 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074 }\pard\intbl\itap1\sl260{\fs18 \par{\uc0\u1057 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 :  }\par\li300{\uc0\u8212   \uc0\u1044 \uc0\u1088 \uc0\u1091 \uc0\u1075 \uc0\u1086 \uc0\u1077 }\par\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1058 \uc0\u1080 \uc0\u1087  \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 : \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 \par \uc0\u1060 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1090  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099 : \uc0\u1085 \uc0\u1072 \uc0\u160 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1077  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1103 \par \line\uc0\u1046 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103  \uc0\u1074  \uc0\u1087 \uc0\u1091 \uc0\u1090 \uc0\u1080  \uc0\u1076 \uc0\u1086  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099 : \uc0\u1085 \uc0\u1077  \uc0\u1080 \uc0\u1084 \uc0\u1077 \uc0\u1077 \uc0\u1090  \uc0\u1079 \uc0\u1085 \uc0\u1072 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 }}\cell \row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1087 \uc0\u1099 \uc0\u1090  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \emdash 18 \uc0\u1083 \uc0\u1077 \uc0\u1090 }\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1060 \uc0\u1077 \uc0\u1074 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100  2022 \emdash  \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1103 \uc0\u1097 \uc0\u1077 \uc0\u1077  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103 \line 4 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072  2 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1072 }\cell\pard\intbl\itap1\par\cell\pard\intbl\itap1\sl280{\fs24\b \uc0\u1054 \uc0\u1054 \uc0\u1054  \uc0\u1057 \uc0\u1086 \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1058 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1080  \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 }\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1057 \uc0\u1072 \uc0\u1085 \uc0\u1082 \uc0\u1090 -\uc0\u1055 \uc0\u1077 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1073 \uc0\u1091 \uc0\u1088 \uc0\u1075 , stp-tech.ru}\par\pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1044 \uc0\u1080 \uc0\u1088 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088  \uc0\u1087 \uc0\u1086  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1072 \uc0\u1084 \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1048 \uc0\u1085 \uc0\u1078 \uc0\u1080 \uc0\u1085 \uc0\u1080 \uc0\u1088 \uc0\u1080 \uc0\u1085 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1103  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 , \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1080  \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1075 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1092 \uc0\u1072 \uc0\u1073 \uc0\u1088 \uc0\u1080 \uc0\u1082 , \uc0\u1043 \uc0\u1054 \uc0\u1050  \uc0\u1080  \uc0\u1047 \uc0\u1048 \uc0\u1060 {\line}{\line}\uc0\u1054 \uc0\u1073 \uc0\u1103 \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 :{\line}- \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1077  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \uc0\u1085 \uc0\u1072  1 \uc0\u1075 \uc0\u1086 \uc0\u1076  \uc0\u1080  3 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072 ;{\line}- \uc0\u1089 \uc0\u1086 \uc0\u1075 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074 ;{\line}- \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079  \uc0\u1080  \uc0\u1082 \uc0\u1086 \uc0\u1088 \uc0\u1088 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081 ;{\line}- \uc0\u1086 \uc0\u1088 \uc0\u1075 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1074 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1095  \uc0\u1089  \uc0\u1074 \uc0\u1099 \uc0\u1089 \uc0\u1096 \uc0\u1080 \uc0\u1084  \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 \uc0\u1084  \uc0\u1082 \uc0\u1086 \uc0\u1088 \uc0\u1087 \uc0\u1086 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1081 /\uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1103 \uc0\u1090 \uc0\u1080 \uc0\u1081 /\uc0\u1043 \uc0\u1054 \uc0\u1050 \uc0\u1086 \uc0\u1074 ;{\line}- \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1080  \uc0\u1087 \uc0\u1086  \uc0\u1075 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1084  \uc0\u1056 \uc0\u1060 .{\line}- \uc0\u1083 \uc0\u1080 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1091 \uc0\u1095 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1077  \uc0\u1074  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1093 \uc0\u1086 \uc0\u1078 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1080  \uc0\u1043 \uc0\u1083 \uc0\u1072 \uc0\u1074 \uc0\u1075 \uc0\u1086 \uc0\u1089 \uc0\u1101 \uc0\u1082 \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u1099 .{\line}{\line}\uc0\u1044 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 :{\line}- \uc0\u1086 \uc0\u1073 \uc0\u1098 \uc0\u1077 \uc0\u1084  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078  \uc0\u1089  \uc0\u1085 \uc0\u1091 \uc0\u1083 \uc0\u1103  \uc0\u1076 \uc0\u1086  100 \uc0\u1084 \uc0\u1083 \uc0\u1085 . \uc0\u1088 \uc0\u1091 \uc0\u1073 \uc0\u1083 \uc0\u1077 \uc0\u1081 ;{\line}- \uc0\u1079 \uc0\u1072 \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1089 \uc0\u1086 \uc0\u1075 \uc0\u1083 \uc0\u1072 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1089  \uc0\u1074 \uc0\u1077 \uc0\u1076 \uc0\u1091 \uc0\u1097 \uc0\u1080 \uc0\u1084 \uc0\u1080  \uc0\u1086 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1083 \uc0\u1077 \uc0\u1074 \uc0\u1099 \uc0\u1084 \uc0\u1080  \uc0\u1080 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1090 \uc0\u1091 \uc0\u1090 \uc0\u1072 \uc0\u1084 \uc0\u1080 ;{\line}- \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1076 \uc0\u1086 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1074  \uc0\u1089  \uc0\u1074 \uc0\u1077 \uc0\u1076 \uc0\u1091 \uc0\u1097 \uc0\u1080 \uc0\u1084 \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1084 \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1103 \uc0\u1090 \uc0\u1080 \uc0\u1103 \uc0\u1084 \uc0\u1080  \uc0\u1056 \uc0\u1060 .}\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1060 \uc0\u1077 \uc0\u1074 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100  2020 \emdash  \uc0\u1071 \uc0\u1085 \uc0\u1074 \uc0\u1072 \uc0\u1088 \uc0\u1100  2022\line 2 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072 }\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1043 \uc0\u1057 \uc0\u1050  \uc0\u1056 \uc0\u1077 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 }\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1045 \uc0\u1082 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1080 \uc0\u1085 \uc0\u1073 \uc0\u1091 \uc0\u1088 \uc0\u1075 , reforma-sk.ru/}\par\pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1047 \uc0\u1072 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100  \uc0\u1075 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1076 \uc0\u1080 \uc0\u1088 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1072  \uc0\u1087 \uc0\u1086  \uc0\u1088 \uc0\u1077 \uc0\u1075 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1084 \uc0\u1091  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1074 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1102 \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1072  \uc0\u1076 \uc0\u1077 \uc0\u1084 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1078 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1091 \uc0\u1089 \uc0\u1083 \uc0\u1091 \uc0\u1075  \uc0\u1080  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1074 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1077  \uc0\u1085 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1080 \uc0\u1085 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1088 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1089 \uc0\u1077 \uc0\u1090 \uc0\u1080 .{\line}{\line}\uc0\u1054 \uc0\u1073 \uc0\u1103 \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 :{\line}- \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079  \uc0\u1088 \uc0\u1099 \uc0\u1085 \uc0\u1082 \uc0\u1072  (\uc0\u1089 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1072 \uc0\u1088 \uc0\u1090 \uc0\u1099  \uc0\u1079 \uc0\u1072 \uc0\u1082 \uc0\u1072 \uc0\u1079 \uc0\u1095 \uc0\u1080 \uc0\u1082 \uc0\u1086 \uc0\u1074 );{\line}- \uc0\u1087 \uc0\u1086 \uc0\u1080 \uc0\u1089 \uc0\u1082  \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082  \uc0\u1089 \uc0\u1086 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1091  \uc0\u1087 \uc0\u1072 \uc0\u1088 \uc0\u1090 \uc0\u1085 \uc0\u1077 \uc0\u1088 \uc0\u1086 \uc0\u1074  - \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1080 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1090 \uc0\u1091 \uc0\u1090 \uc0\u1099 ;{\line}- \uc0\u1086 \uc0\u1088 \uc0\u1075 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1074 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1095 ;{\line}- \uc0\u1074 \uc0\u1099 \uc0\u1077 \uc0\u1079 \uc0\u1076  \uc0\u1080  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1095 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1086 \uc0\u1089 \uc0\u1084 \uc0\u1086 \uc0\u1090 \uc0\u1088  \uc0\u1086 \uc0\u1073 \uc0\u1098 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074 ;{\line}- \uc0\u1089 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 /\uc0\u1086 \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090  (\uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 /\uc0\u1082 \uc0\u1074 \uc0\u1072 \uc0\u1088 \uc0\u1090 \uc0\u1072 \uc0\u1083 /\uc0\u1075 \uc0\u1086 \uc0\u1076 /3 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072 ){\line}- \uc0\u1083 \uc0\u1080 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1091 \uc0\u1095 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1077  \uc0\u1074  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1080  \uc0\u1076 \uc0\u1086 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1074 /\uc0\u1089 \uc0\u1086 \uc0\u1075 \uc0\u1083 \uc0\u1072 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081 ;{\line}- \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1100  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \uc0\u1089  \uc0\u1074 \uc0\u1072 \uc0\u1083 \uc0\u1102 \uc0\u1090 \uc0\u1085 \uc0\u1099 \uc0\u1084  \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1077 \uc0\u1084  (\uc0\u1057 \uc0\u1053 \uc0\u1043 ).{\line}{\line}\uc0\u1044 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 :{\line}- \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1080 \uc0\u1080  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1074 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1103  \uc0\u1088 \uc0\u1099 \uc0\u1085 \uc0\u1082 \uc0\u1072  \uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1093 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1072 /\uc0\u1059 \uc0\u1079 \uc0\u1073 \uc0\u1077 \uc0\u1082 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085  \uc0\u1085 \uc0\u1072  4 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072 ;{\line}- \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1088 \uc0\u1099 \uc0\u1090 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1074 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1072  \uc0\u1074  \uc0\u1056 \uc0\u1050 .}\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1052 \uc0\u1072 \uc0\u1088 \uc0\u1090  2015 \emdash  \uc0\u1060 \uc0\u1077 \uc0\u1074 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100  2020\line 5 \uc0\u1083 \uc0\u1077 \uc0\u1090 }\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1052 \uc0\u1072 \uc0\u1096 \uc0\u1080 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1093 \uc0\u1086 \uc0\u1083 \uc0\u1076 \uc0\u1080 \uc0\u1085 \uc0\u1075 , \uc0\u1040 \uc0\u1054 }\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1045 \uc0\u1082 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1080 \uc0\u1085 \uc0\u1073 \uc0\u1091 \uc0\u1088 \uc0\u1075 , www.mash-hold.ru}\par{\fs18 \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1084 \uc0\u1099 \uc0\u1096 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 , \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1072 , \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1082 \uc0\u1080  \uc0\u1080  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1102 \uc0\u1097 \uc0\u1080 \uc0\u1077 }\par\li300{{\fs18 \uc0\u8226  \uc0\u1054 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1080  \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1082 \uc0\u1080  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1073 \uc0\u1099 \uc0\u1074 \uc0\u1072 \uc0\u1102 \uc0\u1097 \uc0\u1077 \uc0\u1081 , \uc0\u1101 \uc0\u1085 \uc0\u1077 \uc0\u1088 \uc0\u1075 \uc0\u1077 \uc0\u1090 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1081 , \uc0\u1085 \uc0\u1077 \uc0\u1092 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1081  \uc0\u1080  \uc0\u1093 \uc0\u1080 \uc0\u1084 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1081  \uc0\u1086 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1083 \uc0\u1080   (\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 )}}\par {\fs18 \uc0\u1069 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1072 , \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077 , \uc0\u1073 \uc0\u1099 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1103  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1072 , \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1100 \uc0\u1102 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1099  \uc0\u1080  \uc0\u1086 \uc0\u1088 \uc0\u1075 \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1072 }\par\li300{{\fs18 \uc0\u8226  \uc0\u1069 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1086 -\uc0\u1074 \uc0\u1099 \uc0\u1095 \uc0\u1080 \uc0\u1089 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1072 \uc0\u1103 , \uc0\u1086 \uc0\u1087 \uc0\u1090 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1072 \uc0\u1103 , \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 -\uc0\u1080 \uc0\u1079 \uc0\u1084 \uc0\u1077 \uc0\u1088 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1072 , \uc0\u1088 \uc0\u1072 \uc0\u1076 \uc0\u1080 \uc0\u1086 \uc0\u1101 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1072 , \uc0\u1072 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1082 \uc0\u1072  (\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1074 \uc0\u1080 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077 , \uc0\u1086 \uc0\u1087 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1103  \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1083 \uc0\u1103 )}}\par\li300{{\fs18 \uc0\u8226  \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1084 \uc0\u1099 \uc0\u1096 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1077 , \uc0\u1073 \uc0\u1099 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1077  \uc0\u1101 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1080  \uc0\u1101 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1072  (\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1074 \uc0\u1080 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077 , \uc0\u1086 \uc0\u1087 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1103  \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1083 \uc0\u1103 )}}\par\li300{{\fs18 \uc0\u8226  \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1084 \uc0\u1099 \uc0\u1096 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1077 , \uc0\u1073 \uc0\u1099 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1077  \uc0\u1101 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1080  \uc0\u1101 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1072  (\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 )}}\par \pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1056 \uc0\u1091 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100  \uc0\u1086 \uc0\u1090 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1072  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078  - \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1056 \uc0\u1077 \uc0\u1089 \uc0\u1087 \uc0\u1091 \uc0\u1073 \uc0\u1083 \uc0\u1080 \uc0\u1082 \uc0\u1072  \uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1093 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1054 \uc0\u1073 \uc0\u1103 \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 :{\line}- \uc0\u1057 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1077  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1085 \uc0\u1072  1 \uc0\u1080  3 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072 ;{\line}- \uc0\u1054 \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1092 \uc0\u1091 \uc0\u1085 \uc0\u1082 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1072  \uc0\u1080  \uc0\u1085 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1088  \uc0\u1089 \uc0\u1086 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1086 \uc0\u1074 ;{\line}- \uc0\u1057 \uc0\u1086 \uc0\u1075 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1088 \uc0\u1091 \uc0\u1087 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1082 \uc0\u1086 \uc0\u1088 \uc0\u1088 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 ;{\line}- \uc0\u1042 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1095 \uc0\u1080  \uc0\u1089  \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 \uc0\u1084  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1081  \uc0\u1080  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1080  (50% \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1080 );{\line}- \uc0\u1051 \uc0\u1080 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1091 \uc0\u1095 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1077  \uc0\u1074  \uc0\u1080 \uc0\u1089 \uc0\u1087 \uc0\u1099 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 \uc0\u1093  \uc0\u1085 \uc0\u1072  \uc0\u1086 \uc0\u1073 \uc0\u1098 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072 \uc0\u1093 ;{\line}- \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1084 \uc0\u1086 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1086 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1072 .{\line}{\line}\uc0\u1050 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1072 :{\line}\uc0\u1051 \uc0\u1080 \uc0\u1095 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1087 \uc0\u1086 \uc0\u1084 \uc0\u1086 \uc0\u1097 \uc0\u1085 \uc0\u1080 \uc0\u1082  \uc0\u8212  1 \uc0\u1095 \uc0\u1077 \uc0\u1083 .;{\line}\uc0\u1048 \uc0\u1085 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1088  \uc0\u1087 \uc0\u1086  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1072 \uc0\u1084  \uc0\u8212  2 \uc0\u1095 \uc0\u1077 \uc0\u1083 .;{\line}\uc0\u1057 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1080 \uc0\u1085 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1088 \uc0\u1099  \uc0\u8212  5 \uc0\u1095 \uc0\u1077 \uc0\u1083 .;{\line}\uc0\u1050 \uc0\u1083 \uc0\u1072 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1097 \uc0\u1080 \uc0\u1082  \uc0\u8212  2 \uc0\u1095 \uc0\u1077 \uc0\u1083 .{\line}{\line}\uc0\u1050 \uc0\u1072 \uc0\u1088 \uc0\u1100 \uc0\u1077 \uc0\u1088 \uc0\u1072 :{\line}\uc0\u1053 \uc0\u1072 \uc0\u1095 \uc0\u1072 \uc0\u1083  \uc0\u1082 \uc0\u1072 \uc0\u1082  \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1078 \uc0\u1077 \uc0\u1088  \uc0\u1087 \uc0\u1086  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1072 \uc0\u1084 , \uc0\u1095 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1079  2 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072  \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1056 \uc0\u1054 \uc0\u1055  \uc0\u1087 \uc0\u1086  \uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1093 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1091 .{\line}{\line}\uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1080 :{\line}- \uc0\u1054 \uc0\u1087 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1103  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1072  \uc0\u1073 \uc0\u1091 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1080 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072  \uc0\u1080  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1080  \uc0\u1074  \uc0\u1056 \uc0\u1050 ;{\line}- \uc0\u1050 \uc0\u1088 \uc0\u1091 \uc0\u1087 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1082 \uc0\u1083 \uc0\u1080 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1099 : \uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1094 \uc0\u1080 \uc0\u1085 \uc0\u1082 , \uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1093 \uc0\u1084 \uc0\u1099 \uc0\u1089 , \uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1084 \uc0\u1080 \uc0\u1085 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1089  \uc0\u1080  \uc0\u1076 \uc0\u1088 .{\line}{\line}\uc0\u1054 \uc0\u1073 \uc0\u1103 \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 :{\line}- \uc0\u1040 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079  \uc0\u1088 \uc0\u1099 \uc0\u1085 \uc0\u1082 \uc0\u1072 , \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1074 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1095  \uc0\u1080  \uc0\u1080 \uc0\u1089 \uc0\u1087 \uc0\u1099 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1081 ;{\line}- \uc0\u1057 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074  \uc0\u1086 \uc0\u1090 \uc0\u1075 \uc0\u1088 \uc0\u1091 \uc0\u1079 \uc0\u1086 \uc0\u1082  \uc0\u1080  \uc0\u1086 \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 ;{\line}- \uc0\u1051 \uc0\u1080 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1091 \uc0\u1095 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1077  \uc0\u1074  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1080  \uc0\u1076 \uc0\u1086 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1091 \uc0\u1089 \uc0\u1082 \uc0\u1077  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074 ;{\line}- \uc0\u1050 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1080  \uc0\u1087 \uc0\u1086  \uc0\u1056 \uc0\u1050  (50% \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1080 ).{\line}{\line}\uc0\u1044 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 :{\line}- \uc0\u1059 \uc0\u1074 \uc0\u1077 \uc0\u1083 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078  \uc0\u1074  6 \uc0\u1088 \uc0\u1072 \uc0\u1079  \uc0\u1079 \uc0\u1072  2 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072 ;{\line}- \uc0\u1054 \uc0\u1090 \uc0\u1082 \uc0\u1088 \uc0\u1099 \uc0\u1090 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1089 \uc0\u1080 \uc0\u1075 \uc0\u1085 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1089 \uc0\u1082 \uc0\u1083 \uc0\u1072 \uc0\u1076 \uc0\u1072  \uc0\u1074  \uc0\u1056 \uc0\u1050  \uc0\u1080  \uc0\u1085 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1088  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1099 ;{\line}- \uc0\u1057 \uc0\u1086 \uc0\u1075 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1074  \uc0\u1056 \uc0\u1060  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072  \uc0\u1089  \uc0\u1075 \uc0\u1080 \uc0\u1076 \uc0\u1088 \uc0\u1086 \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1084 ;{\line}- \uc0\u1044 \uc0\u1086 \uc0\u1083 \uc0\u1103  \uc0\u1088 \uc0\u1099 \uc0\u1085 \uc0\u1082 \uc0\u1072  \uc0\u1074 \uc0\u1099 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1083 \uc0\u1072  \uc0\u1089  1% \uc0\u1074  2015 \uc0\u1076 \uc0\u1086  25% \uc0\u1074  2019.{\line}{\line}\uc0\u1044 \uc0\u1086 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 :{\line}- \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1074 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1077  \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1093  \uc0\u1086 \uc0\u1090 \uc0\u1085 \uc0\u1086 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081  \uc0\u1089  \uc0\u1048 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1084 , \uc0\u1091 \uc0\u1095 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1077  \uc0\u1074  \uc0\u1074 \uc0\u1099 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1074 \uc0\u1082 \uc0\u1072 \uc0\u1093 , \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072  \uc0\u1089  \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1072 \uc0\u1084 \uc0\u1080 ;{\line}- \uc0\u1055 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1094 \uc0\u1080 \uc0\u1082 \uc0\u1083  \uc0\u1089 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1082 \uc0\u1080  \uc0\u1086 \uc0\u1090  \uc0\u1087 \uc0\u1086 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1072  \uc0\u1082 \uc0\u1083 \uc0\u1080 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072  \uc0\u1076 \uc0\u1086  \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1074 \uc0\u1082 \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1091 \uc0\u1082 \uc0\u1094 \uc0\u1080 \uc0\u1080 ;{\line}- \uc0\u1056 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072  \uc0\u1089  1\uc0\u1057 , \uc0\u1073 \uc0\u1072 \uc0\u1085 \uc0\u1082 \uc0\u1086 \uc0\u1084  \uc0\u1080  \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1088 \uc0\u1090 \uc0\u1085 \uc0\u1099 \uc0\u1084 \uc0\u1080  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 \uc0\u1084 \uc0\u1080 .}\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1040 \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1083 \uc0\u1100  2008 \emdash  \uc0\u1052 \uc0\u1072 \uc0\u1088 \uc0\u1090  2015\line 7 \uc0\u1083 \uc0\u1077 \uc0\u1090 }\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1054 \uc0\u1054 \uc0\u1054  "Kirby"/\uc0\u1054 \uc0\u1054 \uc0\u1054  \uc0\u171 \uc0\u1057 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1081 \uc0\u1073 \uc0\u1072 \uc0\u1079 \uc0\u1072  \uc0\u8470 1\uc0\u187 /\uc0\u1047 \uc0\u1040 \uc0\u1054  "\uc0\u1063 \uc0\u1077 \uc0\u1083 \uc0\u1103 \uc0\u1073 \uc0\u1080 \uc0\u1085 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1079 \uc0\u1072 \uc0\u1074 \uc0\u1086 \uc0\u1076  \uc0\u1082 \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 "}\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1063 \uc0\u1077 \uc0\u1083 \uc0\u1103 \uc0\u1073 \uc0\u1080 \uc0\u1085 \uc0\u1089 \uc0\u1082 }\par\pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1052 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1078 \uc0\u1077 \uc0\u1088  \uc0\u1087 \uc0\u1086  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1072 \uc0\u1084 \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1054 \uc0\u1054 \uc0\u1054  "Kirby" - \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1072  \uc0\u1087 \uc0\u1099 \uc0\u1083 \uc0\u1077 \uc0\u1089 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1079 \uc0\u1072  100 \uc0\u1090 \uc0\u1099 \uc0\u1089 \uc0\u1103 \uc0\u1095  \uc0\u1088 \uc0\u1091 \uc0\u1073 \uc0\u1083 \uc0\u1077 \uc0\u1081 , \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1078  - 1 \uc0\u1075 \uc0\u1086 \uc0\u1076 .{\line}{\line}\uc0\u1044 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 :{\line}- \uc0\u1095 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1079  \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1072 \uc0\u1090 \uc0\u1099 \uc0\u1074 \uc0\u1072 \uc0\u1083  DPS(\uc0\u1086 \uc0\u1073 \uc0\u1091 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1089 \uc0\u1086 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1086 \uc0\u1074  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1080 ){\line}- \uc0\u1074 \uc0\u1099 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1103 \uc0\u1083  \uc0\u1089 \uc0\u1086 \uc0\u1073 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1085  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 .{\line}{\line}\uc0\u1054 \uc0\u1054 \uc0\u1054  \uc0\u171 \uc0\u1057 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1081 \uc0\u1073 \uc0\u1072 \uc0\u1079 \uc0\u1072  \uc0\u8470 1\uc0\u187  - \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1099  \uc0\u1095 \uc0\u1077 \uc0\u1088 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1081  \uc0\u1086 \uc0\u1090 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1082 \uc0\u1080 , \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1078  - 2 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072 .{\line}{\line}\uc0\u1044 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 :{\line}- \uc0\u1059 \uc0\u1074 \uc0\u1077 \uc0\u1083 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1089 \uc0\u1086 \uc0\u1073 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1090 \uc0\u1072  \uc0\u1089  400.000 \uc0\u1076 \uc0\u1086  1.500.000\uc0\u1088 \uc0\u1091 \uc0\u1073  \uc0\u1079 \uc0\u1072  6\uc0\u1084 \uc0\u1077 \uc0\u1089 .{\line}- \uc0\u1054 \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1095 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1080 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1090 \uc0\u1091 \uc0\u1090 \uc0\u1072 .{\line}\uc0\u1042  \uc0\u1089 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1077  \uc0\u1082 \uc0\u1083 \uc0\u1080 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 : "\uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1074 \uc0\u1094 \uc0\u1099 " - 95%, \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1090 .\uc0\u1086 \uc0\u1088 \uc0\u1075 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  - 5%{\line}{\line}\uc0\u1047 \uc0\u1040 \uc0\u1054  "\uc0\u1063 \uc0\u1077 \uc0\u1083 \uc0\u1103 \uc0\u1073 \uc0\u1080 \uc0\u1085 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1079 \uc0\u1072 \uc0\u1074 \uc0\u1086 \uc0\u1076  \uc0\u1082 \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 " - \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086  \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1072  \uc0\u1082 \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1080  \uc0\u1079 /\uc0\u1095 ., \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1078  - 2 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072 .{\line}{\line}\uc0\u1044 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 : {\line}- \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1091 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1079 \uc0\u1072 \uc0\u1103 \uc0\u1074 \uc0\u1082 \uc0\u1080  \uc0\u1085 \uc0\u1072  100% \uc0\u1079 \uc0\u1072 \uc0\u1075 \uc0\u1088 \uc0\u1091 \uc0\u1079 \uc0\u1082 \uc0\u1091  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1072  \uc0\u1085 \uc0\u1072  \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1072  \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072  \uc0\u1074  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1099 \uc0\u1081  \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 ;{\line}- \uc0\u1079 \uc0\u1072 \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1089  \uc0\u1074 \uc0\u1077 \uc0\u1076 \uc0\u1091 \uc0\u1097 \uc0\u1080 \uc0\u1084 \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1103 \uc0\u1090 \uc0\u1080 \uc0\u1103 \uc0\u1084 \uc0\u1080  \uc0\u1056 \uc0\u1060 {\line}\uc0\u1042  \uc0\u1089 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1077  \uc0\u1082 \uc0\u1083 \uc0\u1080 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 : \uc0\u1057 \uc0\u1080 \uc0\u1083 \uc0\u1100 \uc0\u1074 \uc0\u1080 \uc0\u1085 \uc0\u1080 \uc0\u1090 (\uc0\u1059 \uc0\u1088 \uc0\u1072 \uc0\u1083  \uc0\u1050 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1081 ), \uc0\u1058 \uc0\u1043 \uc0\u1050 -14, \uc0\u1057 \uc0\u1057 \uc0\u1043 \uc0\u1055 \uc0\u1054  (\uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1093 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 ), \uc0\u1052 \uc0\u1072 \uc0\u1081 \uc0\u1082 \uc0\u1072 \uc0\u1081 \uc0\u1085 \uc0\u1079 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1090 \uc0\u1086  (\uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1093 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 ), \uc0\u1052 \uc0\u1059 \uc0\u1055 , \uc0\u1060 \uc0\u1043 \uc0\u1059 \uc0\u1055 .}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sl220{\fs22\uc0\u1042 \uc0\u1099 \uc0\u1089 \uc0\u1096 \uc0\u1077 \uc0\u1077 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2010\line \uc0\u1042 \uc0\u1099 \uc0\u1089 \uc0\u1096 \uc0\u1077 \uc0\u1077 }\cell\pard\intbl\itap1\sl280{\fs24\b \uc0\u1070 \uc0\u1078 \uc0\u1085 \uc0\u1086 -\uc0\u1059 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1075 \uc0\u1086 \uc0\u1089 \uc0\u1091 \uc0\u1076 \uc0\u1072 \uc0\u1088 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1091 \uc0\u1085 \uc0\u1080 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1090 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1052 \uc0\u1077 \uc0\u1078 \uc0\u1076 \uc0\u1091 \uc0\u1085 \uc0\u1072 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1085 \uc0\u1099 \uc0\u1081 , \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1078 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090  \uc0\u1086 \uc0\u1088 \uc0\u1075 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1053 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1047 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1103 \uc0\u1079 \uc0\u1099 \uc0\u1082 \uc0\u1086 \uc0\u1074 }\cell\pard\intbl\itap1\sl260{\fs18 \uc0\u1056 \uc0\u1091 \uc0\u1089 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  {\cf1\emdash  \uc0\u1056 \uc0\u1086 \uc0\u1076 \uc0\u1085 \uc0\u1086 \uc0\u1081 }\par \uc0\u1040 \uc0\u1085 \uc0\u1075 \uc0\u1083 \uc0\u1080 \uc0\u1081 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  {\cf1\emdash  B1 \uc0\u8212  \uc0\u1057 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1085 \uc0\u1080 \uc0\u1081 }}\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1053 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }\cell\pard\intbl\itap1\sb250\sl260{\fs18 {\cb5\chcfpat5\chcbpat5 \uc0\u1056 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1073 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1059 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077 \~\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1072 \uc0\u1084 \uc0\u1080 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1040 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1099 \uc0\u1077 \~\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1080 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1054 \uc0\u1088 \uc0\u1075 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1077 \~\uc0\u1085 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1057 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1077 \~\uc0\u1084 \uc0\u1099 \uc0\u1096 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077 }}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1087 \uc0\u1099 \uc0\u1090  \uc0\u1074 \uc0\u1086 \uc0\u1078 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa100\sl280{\fs18\uc0\u1048 \uc0\u1084 \uc0\u1077 \uc0\u1077 \uc0\u1090 \uc0\u1089 \uc0\u1103  \uc0\u1089 \uc0\u1086 \uc0\u1073 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1072 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1086 \uc0\u1073 \uc0\u1080 \uc0\u1083 \uc0\u1100 \par \uc0\u1055 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1072  \uc0\u1082 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1086 \uc0\u1088 \uc0\u1080 \uc0\u1080  B}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1044 \uc0\u1086 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1080 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1056 \uc0\u1077 \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1076 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 }\cell\pard\intbl\itap1\sl260{\fs18 \uc0\u1087 \uc0\u1086  \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1091 \par{\cf1 \uc0\u1087 \uc0\u1086  \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1091  (\uc0\u1087 \uc0\u1086  \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1091 )}}\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1054 \uc0\u1073 \uc0\u1086  \uc0\u1084 \uc0\u1085 \uc0\u1077 }\cell\pard\intbl\itap1\sb250\sl260{\fs18 \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1085 \uc0\u1080 \uc0\u1082  \uc0\u1089  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1084 \uc0\u1080  \uc0\u1084 \uc0\u1086 \uc0\u1079 \uc0\u1075 \uc0\u1072 \uc0\u1084 \uc0\u1080  - \uc0\u1092 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1082 \uc0\u1086 -\uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1072 \uc0\u1103  \uc0\u1096 \uc0\u1082 \uc0\u1086 \uc0\u1083 \uc0\u1072 , \uc0\u1086 \uc0\u1087 \uc0\u1099 \uc0\u1090  \uc0\u1074 \uc0\u1079 \uc0\u1072 \uc0\u1080 \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1080 \uc0\u1103  \uc0\u1089  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1085 \uc0\u1099 \uc0\u1084  \uc0\u1086 \uc0\u1092 \uc0\u1080 \uc0\u1089 \uc0\u1086 \uc0\u1084  \uc0\u1052 \uc0\u1060 \uc0\u1058 \uc0\u1048  \uc0\u1074  \uc0\u1095 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1080  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1087 \uc0\u1072 \uc0\u1088 \uc0\u1090 \uc0\u1085 \uc0\u1105 \uc0\u1088 \uc0\u1089 \uc0\u1090 \uc0\u1074  \uc0\u1089  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1084 \uc0\u1099 \uc0\u1096 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1084 \uc0\u1080  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 \uc0\u1084 \uc0\u1080 . \uc0\u1043 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1088 \uc0\u1102  \uc0\u1085 \uc0\u1072  \uc0\u1086 \uc0\u1076 \uc0\u1085 \uc0\u1086 \uc0\u1084  \uc0\u1103 \uc0\u1079 \uc0\u1099 \uc0\u1082 \uc0\u1077  \uc0\u1089  \uc0\u1080 \uc0\u1085 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1080 , \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1072 \uc0\u1084 \uc0\u1080  \uc0\u1080  \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1103 \uc0\u1084 \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1090 \uc0\u1074 .{\line}{\line}\uc0\u1055 \uc0\u1088 \uc0\u1086  \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1103  \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1088 \uc0\u1103 \uc0\u1090 : \uc0\u1085 \uc0\u1072 \uc0\u1093 